# AeroBus docker-compose environment.
#
# Copy to `.env` (same directory as docker-compose.yml) and set real values
# before `docker compose up`. Compose substitutes ${VAR:-default} from here.
# The defaults are dev-only throwaways — override BOTH for anything shared.

# DocumentForge API key (Bearer auth on dfdb). Shared by DocumentForge itself,
# by RuleForge (RULEFORGE_DF_API_KEY), and by AeroBus (DocumentForge__ApiKey).
# Keep it identical across all three services or they can't talk to the DB.
DFDB_API_KEY=aerobus-dev-key

# RuleForge caller shared secret. AeroBus sends it as the X-AERO-Key header;
# RuleForge is started with the same value (RULEFORGE_API_KEY). Must match on
# both sides or every RuleForge decision call is rejected.
RULEFORGE_API_KEY=aerobus-dev-ruleforge-key
