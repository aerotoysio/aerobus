{
  "id": "rule-shop-bundles",
  "name": "Offer shop · fare bundles (per-bundle markup + O&D base fare)",
  "description": "For each catalogue bundle in the request, build a priced fare: base = O&D base fare (ref-basefares) x the bundle's tier markup (ref-bundle-markups by code), a 10% tax component, total = base + taxes. Echoes eligiblePaxIds from the request. Emits { bundles: [...] } for POST /v1/offer/shop-bundles. Prices are emitted as flat base/taxes/total fields (RuleForge calc/mutator targets are top-level keys, not nested paths); the AeroBus mapper folds them into the price object.",
  "tags": ["offer", "shop", "bundles"],
  "category": "Offer",
  "endpoint": "/v1/offer/shop-bundles",
  "method": "POST",
  "status": "draft",
  "currentVersion": 0,
  "inputSchema": {
    "type": "object",
    "properties": {
      "searchContext": { "type": "object" },
      "flightSolution": { "type": "object" },
      "passengers": { "type": "array" },
      "paxIds": { "type": "array" },
      "bundles": { "type": "array" },
      "products": { "type": "array" }
    },
    "required": ["bundles"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "bundles": { "type": "array" }
    }
  },
  "nodes": [
    {
      "id": "n1-input", "type": "input",
      "position": { "x": 40, "y": 240 },
      "data": { "label": "Shop request", "category": "input" }
    },
    {
      "id": "n2-foreach", "type": "iterator",
      "position": { "x": 260, "y": 240 },
      "data": {
        "label": "For each catalogue bundle", "category": "iterator",
        "config": { "source": "$.bundles", "as": "bundle" }
      }
    },
    {
      "id": "n3-shell", "type": "constant",
      "position": { "x": 480, "y": 240 },
      "data": {
        "label": "Fare shell", "category": "constant",
        "config": {
          "value": {
            "bundleId": "",
            "code": "",
            "name": "",
            "currency": "AED",
            "markup": 1.0,
            "baseFare": 0,
            "base": 0,
            "taxes": 0,
            "total": 0
          }
        }
      }
    },
    {
      "id": "n4-ids", "type": "mutator",
      "position": { "x": 700, "y": 140 },
      "data": {
        "label": "Set id/code/name/currency + eligiblePaxIds", "category": "mutator",
        "config": {
          "sets": [
            { "target": "bundleId", "from": "$bundle.id" },
            { "target": "code", "from": "$bundle.code" },
            { "target": "name", "from": "$bundle.name" },
            { "target": "currency", "from": "$.searchContext.currency" },
            { "target": "eligiblePaxIds", "from": "$.paxIds" }
          ]
        }
      }
    },
    {
      "id": "n5-basefare", "type": "mutator",
      "position": { "x": 940, "y": 140 },
      "data": {
        "label": "Lookup O&D base fare", "category": "mutator", "templateId": "cus-price-lookup",
        "config": {
          "target": "baseFare",
          "lookup": {
            "referenceId": "ref-basefares",
            "valueColumn": "fare",
            "matchOn": {
              "origin": "$.flightSolution.origin",
              "destination": "$.flightSolution.destination"
            }
          },
          "onMissing": "leave"
        }
      }
    },
    {
      "id": "n6-markup", "type": "mutator",
      "position": { "x": 1180, "y": 140 },
      "data": {
        "label": "Lookup tier markup", "category": "mutator", "templateId": "cus-price-lookup",
        "config": {
          "target": "markup",
          "lookup": {
            "referenceId": "ref-bundle-markups",
            "valueColumn": "markup",
            "matchOn": { "code": "$bundle.code" }
          },
          "onMissing": "leave"
        }
      }
    },
    {
      "id": "n7-base", "type": "calc",
      "position": { "x": 1420, "y": 140 },
      "data": {
        "label": "base = baseFare * markup", "category": "calc", "templateId": "cus-markup",
        "config": { "target": "base", "expression": "baseFare * markup" }
      }
    },
    {
      "id": "n8-taxes", "type": "calc",
      "position": { "x": 1660, "y": 140 },
      "data": {
        "label": "taxes = base * 0.10", "category": "calc",
        "config": { "target": "taxes", "expression": "base * 0.10" }
      }
    },
    {
      "id": "n9-total", "type": "calc",
      "position": { "x": 1900, "y": 140 },
      "data": {
        "label": "total = base + taxes", "category": "calc",
        "config": { "target": "total", "expression": "base + taxes" }
      }
    },
    {
      "id": "n10-merge", "type": "merge",
      "position": { "x": 2140, "y": 240 },
      "data": { "label": "Collect fares", "category": "merge", "config": { "mode": "collect" } }
    },
    {
      "id": "n11-output", "type": "output",
      "position": { "x": 2380, "y": 240 },
      "data": { "label": "Result (bundle array)", "category": "output" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "n1-input", "target": "n2-foreach", "branch": "default" },
    { "id": "e2", "source": "n2-foreach", "target": "n3-shell", "branch": "pass" },
    { "id": "e3", "source": "n3-shell", "target": "n4-ids", "branch": "default" },
    { "id": "e4", "source": "n4-ids", "target": "n5-basefare", "branch": "default" },
    { "id": "e5", "source": "n5-basefare", "target": "n6-markup", "branch": "default" },
    { "id": "e6", "source": "n6-markup", "target": "n7-base", "branch": "default" },
    { "id": "e7", "source": "n7-base", "target": "n8-taxes", "branch": "default" },
    { "id": "e8", "source": "n8-taxes", "target": "n9-total", "branch": "default" },
    { "id": "e9", "source": "n9-total", "target": "n10-merge", "branch": "default" },
    { "id": "e10", "source": "n10-merge", "target": "n11-output", "branch": "default" }
  ],
  "updatedAt": "2026-07-08T00:00:00.000Z",
  "updatedBy": "phase4-seed"
}
