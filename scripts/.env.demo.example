# Demo-environment settings for scripts/run-demo.ps1.
# Copy to scripts/.env.demo (git-ignored) and fill in the two secrets.

DocumentForge__BaseUrl=https://documentforge.demo.aerotoys.io
# An admin-scoped DocumentForge key (provisioning creates tenant databases).
# Mint/inspect via DF Studio or GET /admin/keys on the demo node.
DocumentForge__ApiKey=
# Empty = the server's default database for unauthenticated/control reads;
# authenticated org requests are tenant-routed regardless.
DocumentForge__Database=

Keycloak__BaseUrl=https://auth.demo.aerotoys.io
Keycloak__Realm=aerotoys
# The 'aerobus' client secret — printed by aeroauth/scripts/setup-realm.mjs.
Keycloak__ClientSecret=

# Local RuleForge if you run one; decision points degrade to Allow when down.
RuleForge__BaseUrl=http://localhost:5050
